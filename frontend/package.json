{
  "name": "recoder-frontend",
  "private": true,
  "version": "1.10.1",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win portable"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "opencc-js": "^1.0.5",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.recorder.app",
    "productName": "Recorder",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/electron{,/**/*}"
    ],
    "extraResources": [
      {
        "from": "../whisper_cli",
        "to": "whisper_cli",
        "filter": ["**/*"]
      },
      {
        "from": "../ffmpeg",
        "to": "ffmpeg",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "portable",
      "icon": "../assets/app.ico"
    },
    "portable": {
      "artifactName": "Recorder-${version}-portable.exe"
    }
  }
}